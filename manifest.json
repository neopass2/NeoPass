{
  "manifest_version": 3,
  "name": "NeoExamShield",
  "version": "2.0",
  "description": "AI-powered exam assistant for the Iamneo portal. Requires login for AI features.",
  "background": {
    "service_worker": "worker.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "config.js",
        "devtools.js",
        "data/inject/anti-anti-debug.js",
        "data/inject/copyOverride.js",
        "data/inject/customPaste.js",
        "data/inject/mock_code.js",
        "data/inject/exam.js",
        "data/lib/showdown.min.js",
        "metadata.json",
        "background.js",
        "content/scripts/contentScript.js",
        "manifest.json",
        "data/inject/mock_code/manifest.json",
        "data/inject/mock_code/minifiedBackground.js",
        "data/inject/mock_code/minifiedContent-script.js",
        "data/inject/mock_code/rules.json",
        "data/inject/netacadDomHelper.js",
        "data/inject/netacad.js",
        "data/lib/crypto-js.min.js",
        "data/inject/examlyInterceptor.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "permissions": [
    "management",
    "tabs",
    "activeTab",
    "contextMenus",
    "clipboardWrite",
    "clipboardRead",
    "storage",
    "scripting",
    "downloads",
    "windows",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms",
    "webRequest"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "key": "",
  "externally_connectable": {
    "matches": [
      "http://*/*",
      "https://*/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "data/inject/copyOverride.js",
        "data/inject/customPaste.js",
        "data/inject/rightclickmenu.js",
        "data/inject/isolated.js",
        "data/inject/content.js",
        "data/inject/main.js",
        "content/scripts/contentScript.js",
        "content/scripts/toastManager.js"
      ],
      "css": [
        "content/styles/toasts.css"
      ],
      "exclude_matches": [
        "*://*.discord.com/*",
        "*://*.figma.com/*"
      ]
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "js": [
        "devtools.js"
      ]
    },
    {
      "matches": [
        "https://*.netacad.com/*"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "data/inject/netacadDomHelper.js",
        "data/inject/netacad.js"
      ]
    }
  ],
  "commands": {
    "customPaste": {
      "suggested_key": {
        "default": "Alt+Shift+V",
        "mac": "Alt+Shift+V"
      },
      "description": "Paste using drag-and-drop when blocked"
    },
    "selectedTextAI": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Ask AI about the currently selected text"
    },
    "batchSolve": {
      "suggested_key": {
        "default": "Alt+Shift+Q",
        "mac": "Alt+Shift+Q"
      },
      "description": "Batch solve (auto-mark answers)"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "version_name": "Release Version"
}